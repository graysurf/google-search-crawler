VENV_DIR="$PWD/.venv"
export VIRTUAL_ENV="$VENV_DIR"
export PROJECT_PATH="$PWD"

if ! command -v uv >/dev/null 2>&1; then
  echo "[direnv] uv not found; install uv and run: uv sync --locked" >&2
  return 1
fi

if ! uv sync --locked --check >/dev/null 2>&1; then
  uv sync --locked || return $?
fi

if [[ -d "$VIRTUAL_ENV/bin" ]]; then
  PATH_add "$VIRTUAL_ENV/bin"
elif [[ -d "$VIRTUAL_ENV/Scripts" ]]; then
  PATH_add "$VIRTUAL_ENV/Scripts"
else
  echo "[direnv] .venv not found after uv sync --locked" >&2
  return 1
fi

dotenv_if_exists .env
